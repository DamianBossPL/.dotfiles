{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "control-center-margin-top": 5,
  "control-center-margin-bottom": 5,
  "control-center-margin-right": 5,
  "control-center-margin-left": 0,
  "notification-inline-replies": true,
  "control-center-width": 450,
  "notification-window-width": 400,
  "notification-grouping": false,
  "transition-time": 0,
  "hide-on-action": false,
  "timeout-low": 4,
  "timeout": 8,
  "widget-config": {
    "inhibitors": {
      "clear-all-button": false
    }
  },
  "script-fail-notify": false,
  "scripts": {
    "notification-sound-by-name": {
      "exec": "~/.config/swaync/scripts/name",
      "run-on": "receive",
      "sound-name": ".*"
    },
    "notification-sound-by-file": {
      "exec": "~/.config/swaync/scripts/file",
      "run-on": "receive",
      "sound-file": ".*"
    },
    "notification-sound-low": {
      "exec": "~/.config/swaync/scripts/low",
      "run-on": "receive",
      "urgency": "Low",
      "app-name": "^(?!discord|spotify|vesktop).*$"
    },
    "notification-sound-normal": {
      "exec": "~/.config/swaync/scripts/normal",
      "run-on": "receive",
      "urgency": "Normal",
      "app-name": "^(?!discord|spotify|vesktop).*$"
    },
    "notification-sound-critical": {
      "exec": "~/.config/swaync/scripts/critical",
      "run-on": "receive",
      "urgency": "Critical",
      "app-name": "^(?!discord|spotify|vesktop).*$"
    }
  }
}
