include "$HOME/.cache/wal/colors-sway"

output * bg $wallpaper fill

client.focused $foreground $foreground $foreground $foreground $foreground
client.unfocused $background $background $background $background $background
client.focused_inactive $background $background $background $background $background
client.urgent $color1 $color1 $color1 $color1 $color1

font "Agave Nerd Font Propo" 10
titlebar_border_thickness 0
titlebar_padding 0 0

gaps inner 8
gaps outer 0

default_border pixel 2
default_floating_border pixel 2
floating_maximum_size -1 x -1

corner_radius 16

blur enable
blur_xray off
blur_passes 2
blur_radius 5

focus_follows_mouse no